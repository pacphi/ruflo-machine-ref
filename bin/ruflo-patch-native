#!/usr/bin/env bash
#
# ruflo-patch-native — make ruflo use native better-sqlite3 on modern Node.
#
# WHY: ruflo's deeper `agentdb` packages pin better-sqlite3@^11.8.1, which:
#   - ships prebuilt binaries only up to NODE_MODULE_VERSION 131 (Node 22), and
#   - does NOT compile against Node 24/26's V8 headers.
# On Node >= 24 those optional deps silently fail to install, so agentdb falls
# back to the sql.js (WASM) backend — whose write path has data-loss bugs
# (silent no-op writes, WAL blindness, no-op deletes).
#
# better-sqlite3 @^12 HAS prebuilts for Node 24 (ABI 137) and Node 26 (ABI 147)
# and is API-compatible with agentdb's v11-era usage (verified: no breakage).
# `@claude-flow/memory` already pins ^12.9.0; only the deeper agentdb copies lag.
#
# This helper installs better-sqlite3@^12 into every agentdb location that lacks
# a native binary, so those subsystems (neural, vector-unified, swarm memory,
# agentic-flow) use native SQLite too.
#
# IDEMPOTENT + RE-RUNNABLE: safe to run any time. RE-RUN AFTER EVERY ruflo
# UPGRADE — `npm install -g ruflo@latest` re-resolves the ^11.8.1 pin and wipes
# the patch.
#
# Node version gate:
#   Node <= 22 (ABI <= 127): ^11.8.1 works natively → no patch needed (no-op).
#   Node >= 24 (ABI >= 137): patch applied.
#   Override with --force to patch regardless.
#
# Usage:
#   ruflo-patch-native            # detect + patch if needed
#   ruflo-patch-native --check    # report only, make no changes
#   ruflo-patch-native --force    # patch even on Node <= 22
#   ruflo-patch-native --version 12.10.0   # pin an exact bsq3 version
#   ruflo-patch-native --help
#
# Exit codes: 0 ok / no-op, 1 patch attempted but verification failed, 2 env error

set -u

BSQ_RANGE="^12"
MODE="apply"
FORCE=0

while (( $# )); do
	case "$1" in
		--check) MODE="check" ;;
		--force) FORCE=1 ;;
		--version) shift; BSQ_RANGE="$1" ;;
		-h|--help) sed -n '3,40p' "$0" | sed 's|^# \{0,1\}||'; exit 0 ;;
		*) echo "Unknown flag: $1 (try --help)" >&2; exit 2 ;;
	esac
	shift
done

# Shared helpers (colors, ok/warn/fail/dim, _ruflo_need, native bsq3 primitives)
# from ruflo-lib.sh: installed copy first, then repo-relative (bin/ ↔ ../shell/).
for _cand in "$HOME/.config/ruflo/ruflo-lib.sh" "$(dirname "${BASH_SOURCE[0]:-$0}")/../shell/ruflo-lib.sh"; do
	# shellcheck source=/dev/null
	[ -f "$_cand" ] && { . "$_cand"; break; }
done
unset _cand
[ -n "${_RUFLO_LIB:-}" ] || { echo "ruflo-lib.sh not found — run install.sh" >&2; exit 2; }

_ruflo_need node npm ruflo

NODE_VER=$(node --version)
NODE_ABI=$(_ruflo_node_abi)
RUFLO_ROOT="$(_ruflo_global_root)/ruflo"

echo "Node $NODE_VER (ABI $NODE_ABI) | ruflo $(ruflo --version 2>/dev/null | tr -d '\n')"
echo "ruflo root: $RUFLO_ROOT"
echo ""

# --- Node version gate ------------------------------------------------------
# better-sqlite3 v11 prebuilts cover up to ABI 131 (Node 22). >=137 (Node 24+)
# is where the ^11.8.1 pin breaks and the WASM fallback (with its bugs) kicks in.
if (( NODE_ABI <= 131 )) && (( ! FORCE )); then
	ok "Node $NODE_VER (ABI $NODE_ABI) <= 22: better-sqlite3@^11.8.1 builds natively here."
	dim "   No patch needed. (Use --force to patch anyway.)"
	exit 0
fi

if (( NODE_ABI >= 137 )); then
	warn "Node $NODE_VER (ABI $NODE_ABI) >= 24: agentdb's better-sqlite3@^11.8.1 has no prebuilt and won't compile → WASM fallback (buggy)."
else
	warn "Patching regardless (--force)."
fi
echo ""

# --- Discover agentdb better-sqlite3 locations lacking a native binary -------
# Strategy: for each `agentdb` package in ruflo's tree, ensure a native
# better-sqlite3 is resolvable from it. If not, install one into that agentdb's
# own node_modules.
# bash 3.2 compatible (macOS /bin/bash has no `mapfile`)
AGENTDB_DIRS=()
while IFS= read -r _d; do
	[[ -n "$_d" ]] && AGENTDB_DIRS+=("$_d")
done < <(find "$RUFLO_ROOT" -type d -name agentdb -path "*/node_modules/agentdb" 2>/dev/null)

if (( ${#AGENTDB_DIRS[@]} == 0 )); then
	warn "No agentdb packages found under $RUFLO_ROOT — nothing to patch."
	exit 0
fi

needs_patch() {
	# 0 if this agentdb dir cannot resolve a native better-sqlite3 (i.e. needs the patch)
	! _ruflo_bsq3_is_native "$1"
}

TO_PATCH=()
for d in "${AGENTDB_DIRS[@]}"; do
	rel="${d#"$RUFLO_ROOT"/node_modules/}"
	if needs_patch "$d"; then
		echo "  needs patch: $rel"
		TO_PATCH+=("$d")
	else
		dim "  already native: $rel"
	fi
done
echo ""

if (( ${#TO_PATCH[@]} == 0 )); then
	ok "All agentdb instances already resolve native better-sqlite3. Nothing to do."
	exit 0
fi

if [[ "$MODE" == "check" ]]; then
	warn "${#TO_PATCH[@]} agentdb location(s) need patching. Re-run without --check to apply."
	exit 0
fi

# --- Apply: install better-sqlite3 into each agentdb dir ---------------------
echo "Installing better-sqlite3@$BSQ_RANGE into ${#TO_PATCH[@]} location(s)..."
PATCH_LOG=$(mktemp)
patched=0
for d in "${TO_PATCH[@]}"; do
	rel="${d#"$RUFLO_ROOT"/node_modules/}"
	if ( cd "$d" && npm install "better-sqlite3@$BSQ_RANGE" --no-save --no-audit --no-fund >>"$PATCH_LOG" 2>&1 ); then
		ok "patched $rel"
		patched=$((patched+1))
	else
		fail "failed to patch $rel (see $PATCH_LOG)"
	fi
done
echo ""

# --- Verify -----------------------------------------------------------------
echo "Verifying native binaries..."
allnative=1
for d in "${TO_PATCH[@]}"; do
	rel="${d#"$RUFLO_ROOT"/node_modules/}"
	if needs_patch "$d"; then
		fail "$rel still not native"
		allnative=0
	else
		v=$(node -e "
try {
  const p = require.resolve('better-sqlite3', { paths: ['$d'] });
  const pkg = p.split('/better-sqlite3/')[0] + '/better-sqlite3/package.json';
  process.stdout.write(require(pkg).version);
} catch(e){ process.stdout.write('?'); }" 2>/dev/null)
		ok "$rel → native v$v"
	fi
done
echo ""

# --- Functional smoke test --------------------------------------------------
echo "Smoke test (store → retrieve via native path)..."
TMPD=$(mktemp -d)
( cd "$TMPD" || exit 1
  export CLAUDE_FLOW_DB_PATH="$TMPD/.swarm/memory.db"
  ruflo init --minimal --force >/dev/null 2>&1
  ruflo memory init >/dev/null 2>&1
  ruflo memory store -k "patch/verify" --value "native-ok" -n _patch >/dev/null 2>&1
  if command -v sqlite3 >/dev/null 2>&1 \
     && [[ "$(sqlite3 "$TMPD/.swarm/memory.db" "SELECT COUNT(*) FROM memory_entries WHERE key='patch/verify'" 2>/dev/null)" == "1" ]]; then
    echo "  ✓ store persisted on disk"
  else
    echo "  ⚠ store did not persist — check manually"
  fi
)
rm -rf "$TMPD" "$PATCH_LOG"
echo ""

if (( allnative )); then
	ok "Patched $patched location(s). Re-run this after every 'npm install -g ruflo' upgrade."
	exit 0
else
	fail "Some locations still on WASM. See log above."
	exit 1
fi
