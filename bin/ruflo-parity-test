#!/usr/bin/env bash
#
# ruflo-parity-test — repeatable end-to-end smoke test for the ruflo +
# Claude Code MCP-less / CLI-only setup.
#
# Each run creates a fresh isolated test dir under /tmp:
#   /tmp/test-YYYY.MM.DD.<hash>
# where <hash> is a 5-char random lowercase alphanumeric string.
#
# What it verifies (in order, fail-fast):
#   1. ruflo CLI is on PATH
#   2. ruflo-setup-project / ruflo-remove-mcp shell functions are loaded
#   3. ruflo init writes the expected scaffold
#   4. .mcp.json is stripped (no committed-MCP pollution)
#   5. ruflo MCP not registered at user/local/project scope for this dir
#   6. .claude/settings.local.json contains an ABSOLUTE CLAUDE_FLOW_DB_PATH
#      (no unexpanded ${CLAUDE_PROJECT_DIR} literals — that bug silently drops writes)
#   7. Plain-shell parity: store → retrieve → list → stats all agree
#   8. Cross-cwd parity: store from project dir, retrieve from elsewhere
#      using the env var override. Catches cwd-drift regressions.
#   9. Native sqlite3 row count matches what ruflo CLI reports
#  10. WAL is well-behaved (no stale WAL frames left after a checkpoint)
#
# Usage:
#   ruflo-parity-test                  # run + leave the test dir in place for inspection
#   ruflo-parity-test --keep           # explicit keep
#   ruflo-parity-test --cleanup        # remove the test dir on success
#   ruflo-parity-test --verbose        # print every CLI invocation
#   ruflo-parity-test --help
#
# Exit codes:
#   0 — all checks passed
#   1 — at least one check failed (output explains which)
#   2 — environment problem (missing tools, can't load shell functions)

set -u

# --- argv parsing -----------------------------------------------------------
KEEP=1
VERBOSE=0
for arg in "$@"; do
	case "$arg" in
		--keep) KEEP=1 ;;
		--cleanup) KEEP=0 ;;
		--verbose) VERBOSE=1 ;;
		-h|--help)
			sed -n '3,40p' "$0" | sed 's|^# \{0,1\}||'
			exit 0
			;;
		*) echo "Unknown flag: $arg (try --help)" >&2; exit 2 ;;
	esac
done

# Shared helpers (colors C_OK/C_FAIL/C_DIM/C_HEAD/C_RESET, _ruflo_daemon_list) from
# ruflo-lib.sh: installed copy first, then repo-relative (bin/ ↔ ../shell/).
for _cand in "$HOME/.config/ruflo/ruflo-lib.sh" "$(dirname "${BASH_SOURCE[0]:-$0}")/../shell/ruflo-lib.sh"; do
	# shellcheck source=/dev/null
	[ -f "$_cand" ] && { . "$_cand"; break; }
done
unset _cand
[ -n "${_RUFLO_LIB:-}" ] || { echo "ruflo-lib.sh not found — run install.sh" >&2; exit 2; }

# --- test-specific helpers (PASS/FAIL tally, headers) -----------------------
PASS=0
FAIL=0
LOG_FILE=""

log() { printf '%s\n' "$*"; }
head_line() { printf '\n%s%s%s\n' "$C_HEAD" "$*" "$C_RESET"; }
verbose() { (( VERBOSE )) && printf '%s%s%s\n' "$C_DIM" "$*" "$C_RESET" || true; }

check() {
	local name="$1"; shift
	local detail="$1"; shift
	local ok="$1"; shift
	if [[ "$ok" == "ok" ]]; then
		PASS=$((PASS+1))
		printf '  %s✓%s %s — %s\n' "$C_OK" "$C_RESET" "$name" "$detail"
	else
		FAIL=$((FAIL+1))
		printf '  %s✗%s %s — %s\n' "$C_FAIL" "$C_RESET" "$name" "$detail"
	fi
}

# shellcheck disable=SC2329  # invoked via trap below
cleanup_on_exit() {
	local rc=$?
	# Stop the daemon ruflo-setup-project started for this throwaway workspace
	# (issue #3) — orphaned whether or not we keep the dir, since the test is done.
	# The daemon records the RESOLVED (pwd -P) path, so match that too.
	if [[ -n "${TEST_DIR:-}" ]] && command -v _ruflo_daemon_list >/dev/null 2>&1; then
		local _rdir; _rdir="$(cd "$TEST_DIR" 2>/dev/null && pwd -P || echo "$TEST_DIR")"
		local _dp _dws
		while IFS="$(printf '\t')" read -r _dp _dws; do
			[[ "$_dws" == "$_rdir" || "$_dws" == "$TEST_DIR" ]] || continue
			[[ -n "$_dp" ]] && kill "$_dp" 2>/dev/null && log "Stopped test daemon pid=$_dp ($_dws)"
		done <<EOF
$(_ruflo_daemon_list)
EOF
	fi
	if (( FAIL == 0 && KEEP == 0 )) && [[ -n "${TEST_DIR:-}" && -d "$TEST_DIR" ]]; then
		rm -rf "$TEST_DIR"
		log ""
		log "Cleaned up $TEST_DIR (--cleanup, all checks passed)"
	elif [[ -n "${TEST_DIR:-}" && -d "$TEST_DIR" ]]; then
		log ""
		log "Test dir kept at: $TEST_DIR"
		[[ -n "$LOG_FILE" ]] && log "Full log:        $LOG_FILE"
	fi
	exit "$rc"
}
trap cleanup_on_exit EXIT INT TERM

# --- pre-flight: required tools --------------------------------------------
head_line "Pre-flight"

if ! command -v ruflo >/dev/null 2>&1; then
	check "ruflo on PATH" "not found — install ruflo first" "fail"
	exit 2
fi
RUFLO_VERSION=$(ruflo --version 2>/dev/null | head -1)
check "ruflo on PATH" "$(command -v ruflo) ($RUFLO_VERSION)" "ok"

if ! command -v sqlite3 >/dev/null 2>&1; then
	check "sqlite3 on PATH" "not found — needed for raw DB checks" "fail"
	exit 2
fi
check "sqlite3 on PATH" "$(command -v sqlite3)" "ok"

if ! command -v claude >/dev/null 2>&1; then
	check "claude (Claude Code) on PATH" "not found" "fail"
	exit 2
fi
check "claude on PATH" "$(command -v claude)" "ok"

# Source the user's zsh aliases so we get ruflo-setup-project / ruflo-remove-mcp.
# We'll exec each helper through `zsh -c` so the function definitions resolve
# even though THIS script runs under bash.
ALIASES_FILE="$HOME/.config/zsh/aliases.zsh"
if [[ ! -f "$ALIASES_FILE" ]]; then
	check "shell aliases at $ALIASES_FILE" "missing" "fail"
	exit 2
fi
check "shell aliases file" "$ALIASES_FILE" "ok"

# Verify ruflo-setup-project loads
if ! zsh -c "source '$ALIASES_FILE' && type ruflo-setup-project | grep -q 'is a shell function'" 2>/dev/null; then
	check "ruflo-setup-project loads" "function not defined after sourcing aliases" "fail"
	exit 2
fi
check "ruflo-setup-project loads" "function defined" "ok"

# --- create the dated test dir ---------------------------------------------
DATE_TAG=$(date +%Y.%m.%d)
HASH=$(LC_ALL=C tr -dc 'a-z0-9' </dev/urandom 2>/dev/null | head -c 5)
[[ -z "$HASH" ]] && HASH=$(printf '%05d' $((RANDOM % 100000)))
TEST_DIR="/tmp/test-${DATE_TAG}.${HASH}"
LOG_FILE="${TEST_DIR}.log"

head_line "Create test dir"
mkdir -p "$TEST_DIR"
cd "$TEST_DIR" || { check "test dir created" "cannot cd to $TEST_DIR" "fail"; exit 2; }
check "test dir created" "$TEST_DIR" "ok"

# Capture full output to a log file alongside the test dir
exec 3>&1 4>&2
exec > >(tee -a "$LOG_FILE") 2>&1

git init -q
check "git init" "$(pwd)/.git/" "ok"

# --- run ruflo-setup-project (--minimal for speed) -------------------------
head_line "Run ruflo-setup-project"
verbose "Invoking: zsh -c 'source $ALIASES_FILE && ruflo-setup-project --minimal'"
SETUP_OUT=$(zsh -c "source '$ALIASES_FILE' && cd '$TEST_DIR' && ruflo-setup-project --minimal" 2>&1)
SETUP_RC=$?
verbose "$SETUP_OUT"
if (( SETUP_RC == 0 )); then
	check "ruflo-setup-project exits 0" "exit=$SETUP_RC" "ok"
else
	check "ruflo-setup-project exits 0" "exit=$SETUP_RC — see $LOG_FILE" "fail"
	echo "$SETUP_OUT" | tail -20
fi

# --- check 4: .mcp.json was stripped ---------------------------------------
if [[ -f .mcp.json ]]; then
	check ".mcp.json stripped" "still present (cruft from ruflo init)" "fail"
	cat .mcp.json
else
	check ".mcp.json stripped" "absent (good — no committed MCP pollution)" "ok"
fi

# --- check 5: ruflo MCP not registered for this project --------------------
MCP_HITS=$(zsh -c "source '$ALIASES_FILE' && cd '$TEST_DIR' && claude mcp list 2>/dev/null | grep -c '^ruflo'" || true)
if [[ "${MCP_HITS:-0}" -eq 0 ]]; then
	check "ruflo MCP not registered" "claude mcp list shows no ruflo entry" "ok"
else
	check "ruflo MCP not registered" "$MCP_HITS unexpected entry/entries — run ruflo-remove-mcp" "fail"
fi

# --- check 6: settings.local.json has resolved absolute path ---------------
SETTINGS_FILE=".claude/settings.local.json"
if [[ ! -f "$SETTINGS_FILE" ]]; then
	check "settings.local.json present" "missing" "fail"
else
	DB_PATH=$(python3 -c "import json; print(json.load(open('$SETTINGS_FILE')).get('env', {}).get('CLAUDE_FLOW_DB_PATH', ''))" 2>/dev/null)
	# The literal token Claude Code does NOT expand — matched verbatim, never expanded here.
	# shellcheck disable=SC2016
	UNEXPANDED_CPD='${CLAUDE_PROJECT_DIR}'
	if [[ -z "$DB_PATH" ]]; then
		check "CLAUDE_FLOW_DB_PATH set" "absent or unreadable" "fail"
	elif [[ "$DB_PATH" == *"$UNEXPANDED_CPD"* ]]; then
		check "CLAUDE_FLOW_DB_PATH resolved" "literal \${CLAUDE_PROJECT_DIR} present — Claude Code does NOT expand it; writes will silently fail" "fail"
	elif [[ "$DB_PATH" != /* ]]; then
		check "CLAUDE_FLOW_DB_PATH absolute" "not absolute: $DB_PATH" "fail"
	else
		check "CLAUDE_FLOW_DB_PATH resolved-absolute" "$DB_PATH" "ok"
	fi
fi

# --- check 7: plain-shell store→retrieve→list→stats parity ----------------
head_line "Memory parity (plain shell)"

# Resolve cwd to the symlink-free path so the env var matches whatever
# ruflo-setup-project pinned (which uses pwd -P).
RESOLVED_CWD=$(pwd -P)
EXPECTED_DB="${RESOLVED_CWD}/.swarm/memory.db"

# Use the env var so we test the same path Claude Code's Bash tool would use.
export CLAUDE_FLOW_DB_PATH="$EXPECTED_DB"

KEY="parity/probe-$(date +%s)-$HASH"
VAL="parity-test ${DATE_TAG} run=${HASH}"

verbose "store: ruflo memory store -k $KEY ..."
STORE_OUT=$(ruflo memory store -k "$KEY" --value "$VAL" -n parity-test 2>&1)
verbose "$STORE_OUT"
if echo "$STORE_OUT" | grep -q '\[OK\] Data stored successfully'; then
	check "store reports success" "key=$KEY" "ok"
else
	check "store reports success" "no [OK] in output" "fail"
fi

verbose "retrieve"
RETRIEVE_OUT=$(ruflo memory retrieve -k "$KEY" -n parity-test 2>&1)
verbose "$RETRIEVE_OUT"
if echo "$RETRIEVE_OUT" | grep -qF "$VAL"; then
	check "retrieve returns stored value" "round-trip OK" "ok"
elif echo "$RETRIEVE_OUT" | grep -q 'Key not found'; then
	check "retrieve returns stored value" "Key not found — write didn't persist" "fail"
else
	check "retrieve returns stored value" "unexpected output (see log)" "fail"
fi

verbose "list"
LIST_OUT=$(ruflo memory list -n parity-test 2>&1)
verbose "$LIST_OUT"
# Note: `ruflo memory list` truncates long keys in its table (e.g.
# "parity/probe-177999229..."), so match a non-truncated prefix of the key
# AND confirm the listing reports at least one entry.
KEY_PREFIX="${KEY:0:18}"
if echo "$LIST_OUT" | grep -qF "$KEY_PREFIX" && echo "$LIST_OUT" | grep -qE 'Showing [1-9][0-9]* of'; then
	check "list shows the key" "key prefix visible, listing non-empty" "ok"
else
	check "list shows the key" "key prefix '$KEY_PREFIX' not in listing" "fail"
fi

verbose "stats"
STATS_OUT=$(ruflo memory stats 2>&1)
verbose "$STATS_OUT"
ENTRIES=$(echo "$STATS_OUT" | awk -F'[|]' '/Total Entries/ {gsub(/ /, "", $3); print $3}')
if [[ "${ENTRIES:-0}" -ge 1 ]]; then
	check "stats reports >= 1 entry" "Total Entries: $ENTRIES" "ok"
else
	check "stats reports >= 1 entry" "Total Entries: ${ENTRIES:-0}" "fail"
fi

# --- check 9: native sqlite3 agrees ----------------------------------------
head_line "Native sqlite3 cross-check"
DB_FILE="${RESOLVED_CWD}/.swarm/memory.db"
if [[ ! -f "$DB_FILE" ]]; then
	check "DB file exists at expected path" "$DB_FILE" "fail"
else
	check "DB file exists at expected path" "$DB_FILE" "ok"
	NATIVE_COUNT=$(sqlite3 "$DB_FILE" "SELECT COUNT(*) FROM memory_entries" 2>/dev/null)
	if [[ "${NATIVE_COUNT:-0}" -ge 1 ]]; then
		check "native sqlite3 row count" "$NATIVE_COUNT row(s) in memory_entries" "ok"
	else
		check "native sqlite3 row count" "0 rows — write never landed on disk" "fail"
	fi

	NATIVE_KEY=$(sqlite3 "$DB_FILE" "SELECT key FROM memory_entries WHERE key='$KEY'" 2>/dev/null)
	if [[ "$NATIVE_KEY" == "$KEY" ]]; then
		check "native sqlite3 sees our key" "$KEY" "ok"
	else
		check "native sqlite3 sees our key" "key not found in DB" "fail"
	fi
fi

# --- check 10: WAL behavior ------------------------------------------------
WAL_FILE="${DB_FILE}-wal"
if [[ -f "$WAL_FILE" ]]; then
	WAL_SIZE=$(stat -f "%z" "$WAL_FILE" 2>/dev/null || stat -c "%s" "$WAL_FILE" 2>/dev/null)
	MAIN_SIZE=$(stat -f "%z" "$DB_FILE" 2>/dev/null || stat -c "%s" "$DB_FILE" 2>/dev/null)
	if (( WAL_SIZE > MAIN_SIZE )); then
		check "WAL not bloated" "WAL=$WAL_SIZE > main=$MAIN_SIZE — checkpoint with sqlite3 ... 'PRAGMA wal_checkpoint(TRUNCATE)'" "fail"
	else
		check "WAL not bloated" "WAL=$WAL_SIZE main=$MAIN_SIZE" "ok"
	fi
fi

# --- check 8: cross-cwd parity (CD elsewhere, env var pins target) ---------
head_line "Cross-cwd parity"

# Move to /tmp (not the project) and read using the env var. This catches the
# Bash-subprocess cwd-drift regression: if ruflo's read path ignored the env
# var and silently fell back to cwd/.swarm/memory.db, this would fail.
( cd /tmp && CLAUDE_FLOW_DB_PATH="$DB_FILE" ruflo memory retrieve -k "$KEY" -n parity-test >/tmp/.ruflo-cross-cwd-$$ 2>&1 )
if grep -qF "$VAL" "/tmp/.ruflo-cross-cwd-$$"; then
	check "retrieve from foreign cwd via env var" "value round-trips" "ok"
else
	check "retrieve from foreign cwd via env var" "failed — env var override may not be honored" "fail"
fi
rm -f "/tmp/.ruflo-cross-cwd-$$"

# --- summary ---------------------------------------------------------------
exec 1>&3 2>&4

head_line "Summary"
TOTAL=$((PASS + FAIL))
if (( FAIL == 0 )); then
	printf '%s%d/%d checks passed%s\n' "$C_OK" "$PASS" "$TOTAL" "$C_RESET"
	log ""
	log "Test dir: $TEST_DIR"
	log "Full log: $LOG_FILE"
	exit 0
else
	printf '%s%d/%d checks failed%s\n' "$C_FAIL" "$FAIL" "$TOTAL" "$C_RESET"
	log ""
	log "Test dir kept for inspection: $TEST_DIR"
	log "Full log:                     $LOG_FILE"
	exit 1
fi
